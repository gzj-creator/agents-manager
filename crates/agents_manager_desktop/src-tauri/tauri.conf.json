{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agents-manager",
  "version": "0.2.0",
  "identifier": "com.gongzhijie.agentsmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/icon.icns": "icon.icns"
    }
  },
  "app": {
    "windows": [
      {
        "title": "agents-manager warehouse",
        "width": 1460,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 760
      }
    ]
  }
}
